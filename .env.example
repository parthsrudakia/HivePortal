NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Read-only inventory API for internal tools/scripts (GET /api/inventory).
# Callers send it as `Authorization: Bearer <key>`. Leave blank to disable.
INVENTORY_API_KEY=

# Resend — transactional email (rent/balance reminders, room-change & cleaning
# notices, lease-end heads-ups). NY tenants use Gmail instead (GMAIL_* below),
# which doesn't count against the Resend free tier.
RESEND_API_KEY=
RESEND_FROM=Hive Portal <onboarding@resend.dev>
RESEND_REPLY_TO=
# Free-tier guard: once a cap is hit, the rest of the day's emails are queued and
# sent the next day (drained by the daily cron). Defaults: 90/day, 3000/month.
RESEND_DAILY_CAP=90
RESEND_MONTHLY_CAP=3000

# Agreement email drafts (see docs/AGREEMENTS_SETUP.md)
# Personal Gmail — New York correspondence (no letterhead). Sends over SMTP with
# a Gmail App Password (needs 2-Step Verification on the account):
# https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
# The Gmail App Password is also used over IMAP to verify sent agreements
# landed in the Sent folder — enable IMAP in the Gmail settings.
# M365 / Outlook work account — non-NY agreements (with letterhead)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REFRESH_TOKEN=
# SMS rent reminders (Zoom Phone). Texts go out alongside the email reminders
# (balance reminders + the monthly general reminder) to tenants with a phone on
# file. Needs a Zoom Phone number with SMS enabled and a Server-to-Server OAuth
# app with the phone_sms:write:admin scope. Leave blank to disable SMS.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_SMS_FROM=
